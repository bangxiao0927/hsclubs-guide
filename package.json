{
  "name": "hsclubs-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HSclubs Guide is the planned public school-discovery frontend for independent, single-school HSclubs sites. Students use it to find a verified school and then open that school's own club directory.",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix && prettier . --write",
    "lint:check": "eslint . && prettier . --check",
    "type-check": "vue-tsc -b",
    "test:unit": "vitest",
    "test:e2e": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bangxiao0927/hsclubs-guide.git"
  },
  "keywords": [
    "vue",
    "school-discovery"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bangxiao0927/hsclubs-guide/issues"
  },
  "homepage": "https://github.com/bangxiao0927/hsclubs-guide#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
